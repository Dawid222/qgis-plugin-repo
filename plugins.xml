<plugins>
    <pyqgis_plugin name="Wtyczka Dawid" version="0.2">
        <description><![CDATA[Interaktywna mapa OSM Polski z wyborem powiatow (WFS GUGiK). Obsluguje Qt5 i Qt6.]]></description>
        <about><![CDATA[Wtyczka wyswietlajaca interaktywna mape OpenStreetMap z granicami powiatow pobieranymi z WFS GUGiK. Wybor powiatu przez klikniecie na mape lub liste rozwijana. Przycinanie widoku do wybranego powiatu. Kompatybilna z QGIS 3.x (Qt5) oraz QGIS 4.x (Qt6).]]></about>
        <version>0.2</version>
        <qgis_minimum_version>3.16</qgis_minimum_version>
        <homepage>https://dawid222.github.io/wtyczka-dawid</homepage>
